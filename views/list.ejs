<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Task List</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>

    <%- include ('navbar') %>
    <div class="container">
        <h1>Task List Page</h1>
        <form action="/multi-delete" method="POST">
            <button class="delete-selected-button" type="submit">Delete Selected</button>
<ul class="task-list">
    <% for(let task = 0; task < todos.length; task++) { %>
        <li class="task-item">
            <div class="task-title"><%= todos[task].title %></div>
            <div class="task-description"><%= todos[task].description %></div>
        </li>
        <input type="checkbox" class="task-checkbox" id="" name="selectedTask" value="<%= todos[task]._id %>">
        <a href="/update/<%= todos[task]._id %>" class="update-item">Update</a>
        <a href ="/delete/<%= todos[task]._id %>"class="delete-item">Delete</a>
            
    <% } %>
</ul>
        </form>
    </div>

</body>
</html>
