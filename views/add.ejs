<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Task</title>
      <link rel="stylesheet" href="/styles.css">
</head>
<body>
     <%- include ('navbar') %>
<h1>Add Task Page</h1>

<div class="container">
    <form class="todo-form" action="/add" method="POST">
        <input class="form-input" type="text" name="title" placeholder="Task Title" required>
        <textarea class="form-textarea" name="description" placeholder="Task Description" required></textarea>
        <button class="form-button" type="submit">Add New Task</button>
    </form>
</div>
</body>
</html>